<pre><code><a href='https://github.com/ukparliament/egg-timer/blob/main/app/lib/calculations/forwards/commons_only_sitting_days.rb#L55' title='View on GitHub'>55</a>       end</code></pre>
<pre><code><a href='https://github.com/ukparliament/egg-timer/blob/main/app/lib/calculations/forwards/commons_only_sitting_days.rb#L56' title='View on GitHub'>56</a>     end</code></pre>
